{
  "manifest_version": 3,
  "name": "keyboard sim paste",
  "version": "1.0",
  "description": "High-performance keyboard typing simulation from clipboard",
  "permissions": [
    "activeTab",
    "clipboardRead",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "simulate-type": {
      "suggested_key": {
        "default": "Ctrl+Shift+V",
        "mac": "Command+Shift+V"
      },
      "description": "Paste text by simulating keyboard typing"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}